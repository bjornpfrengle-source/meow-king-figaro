rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "bjornpfrengle@gmail.com");
    }
    function isBanned() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) == true;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'role', 'socialHandle', 'catName', 'battleCry', 'catName2', 'battleCry2', 'catThumbnailUrl', 'catThumbnailUrl2', 'allowRepost', 'banned', 'bannedAt', 'bannedBy', 'badges']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 1048576) &&
             isValidOptionalString('socialHandle', 0, 100) &&
             isValidOptionalString('catName', 0, 50) &&
             isValidOptionalString('battleCry', 0, 100) &&
             isValidOptionalString('catName2', 0, 50) &&
             isValidOptionalString('battleCry2', 0, 100) &&
             isValidOptionalString('catThumbnailUrl', 0, 1048576) &&
             isValidOptionalString('catThumbnailUrl2', 0, 1048576) &&
             (!('allowRepost' in request.resource.data) || request.resource.data.allowRepost is bool) &&
             (!('banned' in request.resource.data) || request.resource.data.banned is bool) &&
             (!('badges' in request.resource.data) || request.resource.data.badges is list) &&
             request.resource.data.role in ['admin', 'user'];
    }

    function isValidComment() {
      return hasOnlyAllowedFields(['text', 'userId', 'userName', 'userAvatar', 'catId', 'createdAt', 'likes']) &&
             isValidString('text', 1, 1000) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('userName', 1, 100) &&
             isValidOptionalString('userAvatar', 0, 1048576) &&
             isValidString('catId', 1, 100) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.likes is number;
    }

    function isValidCat() {
      return hasOnlyAllowedFields(['ownerId', 'name', 'cry', 'videoUrl', 'thumbnailUrl', 'score', 'createdAt', 'isVerified', 'selectedCatId', 'breed', 'approximateAge', 'trimStart', 'trimEnd', 'theme']) &&
             request.resource.data.ownerId == request.auth.uid &&
             isValidString('name', 1, 50) &&
             isValidOptionalString('cry', 0, 100) &&
             isValidOptionalString('videoUrl', 1, 2000) &&
             isValidOptionalString('thumbnailUrl', 0, 2000) &&
             isValidOptionalString('theme', 0, 100) &&
             request.resource.data.score is number &&
             request.resource.data.createdAt is timestamp &&
             (!( 'isVerified' in request.resource.data ) || request.resource.data.isVerified is bool) &&
             (!( 'selectedCatId' in request.resource.data ) || request.resource.data.selectedCatId is string) &&
             (!( 'breed' in request.resource.data ) || request.resource.data.breed is string) &&
             (!( 'approximateAge' in request.resource.data ) || request.resource.data.approximateAge is string) &&
             (!( 'trimStart' in request.resource.data ) || request.resource.data.trimStart is number) &&
             (!( 'trimEnd' in request.resource.data ) || request.resource.data.trimEnd is number);
    }

    function isValidReport() {
      return hasOnlyAllowedFields(['reporterId', 'targetType', 'targetId', 'catId', 'reason', 'details', 'status', 'createdAt']) &&
             request.resource.data.reporterId == request.auth.uid &&
             request.resource.data.targetType in ['cat', 'comment'] &&
             isValidString('targetId', 1, 100) &&
             isValidString('reason', 1, 500) &&
             isValidOptionalString('details', 0, 1000) &&
             request.resource.data.status == 'pending' &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidVote() {
      return hasOnlyAllowedFields(['userId', 'catId', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('catId', 1, 100) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidMessage() {
      return hasOnlyAllowedFields(['text', 'userId', 'userName', 'userAvatar', 'createdAt']) &&
             isValidString('text', 1, 1000) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('userName', 1, 100) &&
             isValidOptionalString('userAvatar', 0, 1048576) &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && request.resource.data.role == 'user';
      // Owner may edit their own profile but cannot change their role or ban status
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser() &&
                    request.resource.data.role == resource.data.role &&
                    request.resource.data.get('banned', false) == resource.data.get('banned', false);
      // Admins may update any user (assign roles, ban, unban)
      allow update: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && isValidMessage();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && isValidComment() && request.resource.data.likes == 0;
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
        request.resource.data.likes == resource.data.likes + 1;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /cats/{catId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && isValidCat() && request.resource.data.score == 0;
      allow update: if isAuthenticated() &&
        (
          // Owner can update name, cry, videoUrl but NOT score or createdAt
          (resource.data.ownerId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'cry', 'videoUrl', 'thumbnailUrl']) &&
           isValidString('name', 1, 50) &&
           isValidOptionalString('cry', 0, 100) &&
           isValidOptionalString('videoUrl', 1, 2000) &&
           isValidOptionalString('thumbnailUrl', 0, 2000))
          ||
          // Anyone can increment score by 1 if they are voting
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score']) &&
           request.resource.data.score == resource.data.score + 1 &&
           // Must create a vote document at the same time
           !exists(/databases/$(database)/documents/votes/$(request.auth.uid + '_' + catId)) &&
           existsAfter(/databases/$(database)/documents/votes/$(request.auth.uid + '_' + catId)))
        );
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && isValidVote() && voteId == request.auth.uid + '_' + request.resource.data.catId;
      allow update: if false; // Votes cannot be changed
      allow delete: if isAdmin(); // Allow admin to clear data
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidReport();
      // Admins resolve reports (set status / resolver metadata)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /themes/{themeId} {
      // Anyone signed in can see the roster; only admins manage it
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
  }
}
